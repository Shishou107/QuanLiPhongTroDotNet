@model IEnumerable<QuanLyPhongTro.Models.ViewModels.PaymentListViewModel>
@{
    ViewData["Title"] = "Lịch sử thanh toán";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h4 class="mb-0">Lịch sử thanh toán</h4>
    <a asp-action="Create" class="btn btn-primary"><i class="fas fa-plus me-1"></i> Ghi nhận thanh toán</a>
</div>

<div class="card border-0 shadow-sm">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="bg-light">
                    <tr>
                        <th class="ps-4">Ngày trả</th>
                        <th>Hóa đơn</th>
                        <th>Khách thuê</th>
                        <th>Số tiền</th>
                        <th>Hình thức</th>
                        <th>Ghi chú</th>
                        <th class="text-end pe-4">Hành động</th>
                    </tr>
                </thead>
                <tbody>
                    @if (!Model.Any())
                    {
                        <tr>
                            <td colspan="7" class="text-center py-5 text-muted">Chưa có giao dịch nào</td>
                        </tr>
                    }
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td class="ps-4">
                                <div>@item.PaymentDate.ToString("dd/MM/yyyy")</div>
                                <div class="small text-muted">@item.PaymentDate.ToString("HH:mm")</div>
                            </td>
                            <td class="fw-bold">#@item.InvoiceCode</td>
                            <td>
                                <div>@item.TenantName</div>
                                <div class="small text-muted">Phòng: @item.RoomNumber</div>
                            </td>
                            <td class="text-success fw-bold">+ @item.Amount.ToString("N0") ₫</td>
                             <td>
                                <span class="badge bg-light text-dark border">
                                    @if (item.Method == "1") { <span>Chuyển khoản</span> }
                                    else if (item.Method == "2") { <span>Tiền mặt</span> }
                                    else { @item.Method }
                                </span>
                            </td>
                            <td class="small text-muted">@item.Note</td>
                            <td class="text-end pe-4">
                                <a asp-action="Receipt" asp-route-id="@item.Id" target="_blank" class="btn btn-sm btn-outline-secondary" title="In biên lai"><i class="fas fa-receipt"></i></a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        @if (ViewBag.TotalPages > 1)
        {
            <div class="d-flex justify-content-center my-4 gap-2">
                @if (ViewBag.CurrentPage > 1)
                {
                    <a asp-action="Index" asp-route-page="@(ViewBag.CurrentPage - 1)" class="rounded-circle btn btn-primary px-3 py-2">&laquo;</a>
                }

                @{
                    int startPage = Math.Max(1, ViewBag.CurrentPage - 1);
                    int endPage = Math.Min(ViewBag.TotalPages, startPage + 2);
                    if (endPage - startPage < 2 && startPage > 1)
                    {
                        startPage = Math.Max(1, endPage - 2);
                    }
                }

                @for (int i = startPage; i <= endPage; i++)
                {
                    <a asp-action="Index" asp-route-page="@i" class="rounded-circle btn @(ViewBag.CurrentPage == i ? "btn-primary active" : "btn-outline-primary") px-3 py-2">@i</a>
                }

                @if (ViewBag.CurrentPage < ViewBag.TotalPages)
                {
                    <a asp-action="Index" asp-route-page="@(ViewBag.CurrentPage + 1)" class="rounded-circle btn btn-primary px-3 py-2">&raquo;</a>
                }
            </div>
        }
    </div>
</div>
