@model QuanLyPhongTro.Models.ViewModels.InvoiceDetailViewModel
@{
    ViewData["Title"] = "Chi tiết hóa đơn " + Model.InvoiceCode;
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb mb-1">
                <li class="breadcrumb-item"><a asp-action="Index">Hóa đơn</a></li>
                <li class="breadcrumb-item active">@Model.InvoiceCode</li>
            </ol>
        </nav>
        <h4 class="mb-0">Hóa đơn #@Model.InvoiceCode</h4>
    </div>
    <div class="btn-group">
        <button onclick="window.print()" class="btn btn-outline-secondary"><i class="fas fa-print me-2"></i>In hóa đơn</button>
        @if (Model.DebtAmount > 0)
        {
            <a asp-controller="Payments" asp-action="Create" asp-route-invoiceId="@Model.Id" class="btn btn-success ms-2"><i class="fas fa-hand-holding-usd me-2"></i>Thanh toán</a>
        }
    </div>
</div>

<div class="row">
    <div class="col-md-8">
        <div class="card shadow-sm border-0 mb-4">
            <div class="card-header bg-white py-3">
                <h6 class="mb-0 fw-bold">Nội dung hóa đơn (Tháng @Model.BillingMonth/@Model.BillingYear)</h6>
            </div>
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table align-middle mb-0">
                        <thead class="bg-light">
                            <tr>
                                <th class="ps-4">Dịch vụ/Mục</th>
                                <th class="text-end">Số lượng</th>
                                <th class="text-end">Đơn giá</th>
                                <th class="text-end pe-4">Thành tiền</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model.Details)
                            {
                                <tr>
                                    <td class="ps-4">@item.ServiceName</td>
                                    <td class="text-end">@item.Quantity.ToString("N1")</td>
                                    <td class="text-end">@item.UnitPrice.ToString("N0")</td>
                                    <td class="text-end pe-4 fw-bold">@item.Amount.ToString("N0") ₫</td>
                                </tr>
                            }
                        </tbody>
                        <tfoot>
                            <tr>
                                <td colspan="3" class="text-end fw-bold py-3 ps-4">Tổng cộng:</td>
                                <td class="text-end pe-4 py-3 fw-bold h5 text-primary">@Model.TotalAmount.ToString("N0") ₫</td>
                            </tr>
                        </tfoot>
                    </table>
                </div>
            </div>
        </div>

        <div class="card shadow-sm border-0 mb-4">
            <div class="card-header bg-white py-3">
                <h6 class="mb-0 fw-bold">Lịch sử thanh toán</h6>
            </div>
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-sm align-middle mb-0">
                        <thead>
                            <tr>
                                <th class="ps-4">Ngày</th>
                                <th>Phương thức</th>
                                <th class="text-end pe-4">Số tiền</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (!Model.Payments.Any())
                            {
                                <tr><td colspan="3" class="text-center py-3 text-muted fst-italic">Chưa có lượt thanh toán nào</td></tr>
                            }
                            @foreach (var p in Model.Payments)
                            {
                                <tr>
                                    <td class="ps-4">@p.PaymentDate.ToString("dd/MM/yyyy HH:mm")</td>
                                    <td>
                                        @if (p.Method == "1") { <span>Chuyển khoản</span> }
                                        else if (p.Method == "2") { <span>Tiền mặt</span> }
                                        else { @p.Method }
                                    </td>
                                    <td class="text-end pe-4 fw-bold text-success">@p.Amount.ToString("N0") ₫</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>

    <div class="col-md-4">
        <div class="card shadow-sm border-0 mb-4">
            <div class="card-header bg-white py-3">
                <h6 class="mb-0 fw-bold">Trạng thái & Đối tượng</h6>
            </div>
            <div class="card-body">
                <div class="mb-4">
                    <div class="small text-muted mb-1">Trạng thái:</div>
                    @if (Model.Status == 0) { <span class="badge badge-invoice-unpaid p-2 w-100">Chưa thanh toán</span> }
                    else if (Model.Status == 1) { <span class="badge badge-invoice-partial p-2 w-100">Thanh toán một phần</span> }
                    else if (Model.Status == 2) { <span class="badge badge-invoice-paid p-2 w-100">Đã hoàn thành</span> }
                    else { <span class="badge badge-invoice-overdue p-2 w-100">Quá hạn</span> }
                </div>

                <div class="mb-4">
                    <div class="small text-muted mb-1">Khách thuê:</div>
                    <div class="d-flex align-items-center">
                        <img src="https://ui-avatars.com/api/?name=@Model.Tenant.FullName&background=0D8ABC&color=fff" class="rounded-circle me-2" width="32" height="32">
                        <a asp-controller="Tenants" asp-action="Details" asp-route-id="@Model.Tenant.Id" class="fw-bold text-decoration-none">@Model.Tenant.FullName</a>
                    </div>
                    <div class="small mt-1 text-muted"><i class="fas fa-phone-alt me-1"></i> @Model.Tenant.PhoneNumber</div>
                </div>

                <div class="mb-4">
                    <div class="small text-muted mb-1">Phòng:</div>
                    <div class="fw-bold"><i class="fas fa-door-open me-1 text-primary"></i> @Model.Room.RoomNumber</div>
                    <div class="small text-muted">@Model.Room.BuildingName</div>
                </div>

                <div class="p-3 bg-light rounded shadow-sm">
                    <div class="d-flex justify-content-between mb-2">
                        <span>Đã trả:</span>
                        <span class="text-success fw-bold">@Model.PaidAmount.ToString("N0") ₫</span>
                    </div>
                    <div class="d-flex justify-content-between border-top pt-2">
                        <span class="fw-bold">Còn nợ:</span>
                        <span class="text-danger fw-bold h5 mb-0">@Model.DebtAmount.ToString("N0") ₫</span>
                    </div>
                    @if (Model.DueDate.HasValue)
                    {
                        <div class="mt-3 small text-center text-muted">
                            Hạn cuối: @Model.DueDate.Value.ToString("dd/MM/yyyy")
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>
