@model QuanLyPhongTro.Models.ViewModels.InvoiceCreateViewModel
@{
    ViewData["Title"] = "Lap hoa don";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h4 class="mb-0">Lap hoa don</h4>
    <a asp-action="Index" class="btn btn-outline-secondary">Quay lai</a>
</div>

<div class="card border-0 shadow-sm">
    <div class="card-body">
        <form asp-action="Create" method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
            <div class="row">
                <div class="col-md-6 mb-3">
                    <label asp-for="ContractId" class="form-label"></label>
                    <select asp-for="ContractId" asp-items="ViewBag.Contracts" class="form-select">
                        <option value="">Chon hop dong</option>
                    </select>
                    <span asp-validation-for="ContractId" class="text-danger"></span>
                </div>
                <div class="col-md-3 mb-3">
                    <label asp-for="BillingMonth" class="form-label"></label>
                    <input asp-for="BillingMonth" class="form-control" type="number" min="1" max="12" />
                    <span asp-validation-for="BillingMonth" class="text-danger"></span>
                </div>
                <div class="col-md-3 mb-3">
                    <label asp-for="BillingYear" class="form-label"></label>
                    <input asp-for="BillingYear" class="form-control" type="number" min="2000" max="2100" />
                    <span asp-validation-for="BillingYear" class="text-danger"></span>
                </div>
                <div class="col-md-6 mb-3">
                    <label asp-for="DueDate" class="form-label"></label>
                    <input asp-for="DueDate" class="form-control" type="date" />
                    <span asp-validation-for="DueDate" class="text-danger"></span>
                </div>
            </div>

            <h6 class="mt-3">Chi tiet dich vu</h6>
            <div class="row align-items-end">
                <div class="col-md-5 mb-3">
                    <label class="form-label">Dich vu</label>
                    <select asp-for="Details[0].ServiceId" asp-items="ViewBag.Services" class="form-select">
                        <option value="">Chon dich vu</option>
                    </select>
                </div>
                <div class="col-md-3 mb-3">
                    <label class="form-label">So luong</label>
                    <input asp-for="Details[0].Quantity" class="form-control" type="number" min="0" step="0.01" />
                </div>
                <div class="col-md-3 mb-3">
                    <label class="form-label">Don gia</label>
                    <input asp-for="Details[0].UnitPrice" class="form-control" type="number" min="0" step="1000" />
                </div>
            </div>

            <button type="submit" class="btn btn-primary">Luu</button>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
