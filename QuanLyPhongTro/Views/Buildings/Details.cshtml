@model QuanLyPhongTro.Models.ViewModels.BuildingDetailViewModel
@{
    ViewData["Title"] = "Chi tiết tòa nhà " + Model.Name;
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb mb-1">
                <li class="breadcrumb-item"><a asp-action="Index">Tòa nhà</a></li>
                <li class="breadcrumb-item active">@Model.Name</li>
            </ol>
        </nav>
        <h4 class="mb-0">Tòa nhà: @Model.Name</h4>
    </div>
    <div class="btn-group">
        <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-outline-primary"><i class="fas fa-edit me-2"></i>Chỉnh sửa</a>
        <a asp-controller="Rooms" asp-action="Create" asp-route-buildingId="@Model.Id" class="btn btn-primary ms-2"><i class="fas fa-plus me-2"></i>Thêm phòng vào tòa nhà</a>
    </div>
</div>

<div class="row">
    <div class="col-md-4">
        <div class="card shadow-sm border-0 mb-4">
            <div class="card-header bg-white py-3">
                <h6 class="mb-0 fw-bold">Thông tin tòa nhà</h6>
            </div>
            <div class="card-body">
                <div class="mb-4 text-center">
                    <div class="display-4 text-primary mb-2"><i class="fas fa-building"></i></div>
                    <h5 class="fw-bold">@Model.Name</h5>
                </div>
                
                <div class="mb-3">
                    <div class="small text-muted mb-1">Địa chỉ:</div>
                    <div class="fw-bold small">@Model.Address</div>
                </div>
                
                @if (!string.IsNullOrEmpty(Model.Description))
                {
                    <div class="mb-0">
                        <div class="small text-muted mb-1">Mô tả:</div>
                        <p class="small mb-0">@Model.Description</p>
                    </div>
                }
            </div>
        </div>

        <div class="card shadow-sm border-0 mb-4 bg-primary text-white">
            <div class="card-body">
                <div class="row text-center">
                    <div class="col-6 border-end">
                        <div class="h4 fw-bold mb-0">@Model.Rooms.Count</div>
                        <div class="small opacity-75">Tổng số phòng</div>
                    </div>
                    <div class="col-6">
                        <div class="h4 fw-bold mb-0">@Model.Rooms.Count(r => r.Status == 0)</div>
                        <div class="small opacity-75">Phòng trống</div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="col-md-8">
        <div class="card shadow-sm border-0">
            <div class="card-header bg-white py-3">
                <h6 class="mb-0 fw-bold">Danh sách phòng</h6>
            </div>
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0">
                        <thead>
                            <tr>
                                <th class="ps-4">Số phòng</th>
                                <th>Diện tích</th>
                                <th>Giá thuê</th>
                                <th>Trạng thái</th>
                                <th class="text-end pe-4">Hành động</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (!Model.Rooms.Any())
                            {
                                <tr><td colspan="5" class="text-center py-4 text-muted">Tòa nhà này chưa có phòng nào</td></tr>
                            }
                            @foreach (var room in Model.Rooms)
                            {
                                <tr>
                                    <td class="ps-4 fw-bold">@room.RoomNumber</td>
                                    <td>@(room.Area?.ToString("N1") ?? "0") m²</td>
                                    <td class="fw-bold text-primary">@room.RentPrice.ToString("N0") ₫</td>
                                    <td>
                                        @if (room.Status == 0) { <span class="badge badge-room-empty">Trống</span> }
                                        else if (room.Status == 1) { <span class="badge badge-room-rented">Đang thuê</span> }
                                        else { <span class="badge badge-room-maintenance">Bảo trì</span> }
                                    </td>
                                    <td class="text-end pe-4">
                                        <a asp-controller="Rooms" asp-action="Details" asp-route-id="@room.Id" class="btn btn-sm btn-outline-primary"><i class="fas fa-eye"></i></a>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>
