@model IEnumerable<QuanLyPhongTro.Models.ViewModels.BuildingListViewModel>
@{
    ViewData["Title"] = "Danh sách tòa nhà";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h4 class="mb-0">Quản lý tòa nhà</h4>
    <a asp-action="Create" class="btn btn-primary"><i class="fas fa-plus me-2"></i>Thêm tòa nhà</a>
</div>

<div class="card">
    <div class="card-body">
        <form asp-action="Index" method="get" class="row g-3 mb-4">
            <div class="col-md-4">
                <div class="input-group">
                    <input type="text" name="keyword" class="form-control" placeholder="Tìm tên, địa chỉ..." value="@ViewBag.Keyword">
                    <button class="btn btn-outline-secondary" type="submit"><i class="fas fa-search"></i></button>
                </div>
            </div>
        </form>

        <div class="table-responsive">
            <table class="table table-hover align-middle">
                <thead>
                    <tr>
                        <th>Tên tòa nhà</th>
                        <th>Địa chỉ</th>
                        <th class="text-center">Tổng phòng</th>
                        <th class="text-center">Trạng thái</th>
                        <th class="text-end">Hành động</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>
                                <div class="fw-bold">@item.Name</div>
                            </td>
                            <td><span class="text-muted">@item.Address</span></td>
                            <td class="text-center">
                                <span class="badge bg-light text-dark border">@item.TotalRooms</span>
                            </td>
                            <td class="text-center">
                                <div class="d-flex justify-content-center gap-2">
                                    <span class="badge bg-success" title="Trống">@item.EmptyRooms</span>
                                    <span class="badge bg-primary" title="Đang thuê">@item.RentedRooms</span>
                                    <span class="badge bg-warning" title="Bảo trì">@item.MaintenanceRooms</span>
                                </div>
                            </td>
                            <td class="text-end">
                                <div class="btn-group">
                                    <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary" title="Chi tiết"><i class="fas fa-eye"></i></a>
                                    <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-info" title="Sửa"><i class="fas fa-edit"></i></a>
                                    <button type="button" class="btn btn-sm btn-outline-danger" onclick="deleteBuilding('@item.Id')" title="Xóa"><i class="fas fa-trash"></i></button>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function deleteBuilding(id) {
            if (confirmDelete("Bạn có chắc chắn muốn xóa tòa nhà này? Hành động này không thể hoàn tác nếu đã có dữ liệu liên quan.")) {
                $.post('@Url.Action("Delete")', { id: id }, function (res) {
                    if (res.success) {
                        location.reload();
                    } else {
                        alert(res.message);
                    }
                });
            }
        }
    </script>
}
