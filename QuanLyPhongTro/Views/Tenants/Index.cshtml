@model IEnumerable<QuanLyPhongTro.Models.ViewModels.TenantListViewModel>
@{
    ViewData["Title"] = "Quản lý khách thuê";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h4 class="mb-0">Danh sách khách thuê</h4>
    <a asp-action="Create" class="btn btn-primary"><i class="fas fa-plus me-1"></i> Thêm khách thuê</a>
</div>

<div class="card border-0 shadow-sm mb-4">
    <div class="card-body">
        <form asp-action="Index" method="get" class="row g-3">
            <div class="col-md-8">
                <div class="input-group">
                    <span class="input-group-text bg-white border-end-0"><i class="fas fa-search text-muted"></i></span>
                    <input type="text" name="keyword" class="form-control border-start-0" placeholder="Tìm tên, số điện thoại, email, CCCD..." value="@ViewBag.Keyword">
                </div>
            </div>
            <div class="col-md-4">
                <button type="submit" class="btn btn-primary px-4">Lọc</button>
                <a asp-action="Index" class="btn btn-outline-secondary px-3">Xóa bộ lọc</a>
            </div>
        </form>
    </div>
</div>

<div class="card border-0 shadow-sm">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="bg-light">
                    <tr>
                        <th class="ps-4">Họ và tên</th>
                        <th>Số điện thoại</th>
                        <th>Số CCCD</th>
                        <th>Phòng đang thuê</th>
                        <th>Trạng thái</th>
                        <th class="text-end pe-4">Hành động</th>
                    </tr>
                </thead>
                <tbody>
                    @if (!Model.Any())
                    {
                        <tr>
                            <td colspan="6" class="text-center py-5 text-muted">Không tìm thấy khách thuê nào</td>
                        </tr>
                    }
                    @foreach (var item in Model)
                    {
                        var isRenting = item.TenantStatus == 1;
                        var hasCurrentRoom = isRenting
                            && !string.IsNullOrWhiteSpace(item.CurrentRoom)
                            && item.CurrentRoom != "Chưa có";

                        <tr>
                            <td class="ps-4">
                                <div class="fw-bold">@item.FullName</div>
                                <div class="small text-muted">@item.Email</div>
                            </td>
                            <td>@item.PhoneNumber</td>
                            <td>@item.IdentityNumber</td>
                            <td>
                                @if (hasCurrentRoom)
                                {
                                    <span class="badge bg-info text-dark">@item.CurrentRoom - @item.CurrentBuilding</span>
                                }
                                else
                                {
                                    <span class="text-muted small">N/A</span>
                                }
                            </td>
                            <td>
                                @if (isRenting)
                                {
                                    <span class="badge bg-success-subtle text-success px-3">Đang thuê</span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary-subtle text-secondary px-3">Không thuê</span>
                                }
                            </td>
                            <td class="text-end pe-4">
                                <div class="btn-group btn-group-sm">
                                    <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-outline-info" title="Chi tiết"><i class="fas fa-eye"></i></a>
                                    <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-outline-primary" title="Sửa"><i class="fas fa-edit"></i></a>
                                    <button type="button" class="btn btn-outline-danger" onclick="deleteTenant('@item.Id')" title="Xóa"><i class="fas fa-trash"></i></button>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        @if (ViewBag.TotalPages > 1)
        {
            <div class="d-flex justify-content-center my-4 gap-2">
                @if (ViewBag.CurrentPage > 1)
                {
                    <a asp-action="Index" asp-route-page="@(ViewBag.CurrentPage - 1)" asp-route-keyword="@ViewBag.Keyword" class="rounded-circle btn btn-primary px-3 py-2">&laquo;</a>
                }

                @{
                    int startPage = Math.Max(1, ViewBag.CurrentPage - 1);
                    int endPage = Math.Min(ViewBag.TotalPages, startPage + 2);
                    if (endPage - startPage < 2 && startPage > 1)
                    {
                        startPage = Math.Max(1, endPage - 2);
                    }
                }

                @for (int i = startPage; i <= endPage; i++)
                {
                    <a asp-action="Index" asp-route-page="@i" asp-route-keyword="@ViewBag.Keyword" class="rounded-circle btn @(ViewBag.CurrentPage == i ? "btn-primary active" : "btn-outline-primary") px-3 py-2">@i</a>
                }

                @if (ViewBag.CurrentPage < ViewBag.TotalPages)
                {
                    <a asp-action="Index" asp-route-page="@(ViewBag.CurrentPage + 1)" asp-route-keyword="@ViewBag.Keyword" class="rounded-circle btn btn-primary px-3 py-2">&raquo;</a>
                }
            </div>
        }
    </div>
</div>

@section Scripts {
    <script>
        function deleteTenant(id) {
            if (confirm('Bạn có chắc chắn muốn xóa khách thuê này?')) {
                alert('Chức năng xóa sẽ được thực hiện qua API');
            }
        }
    </script>
}