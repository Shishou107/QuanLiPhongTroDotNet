@model IEnumerable<QuanLyPhongTro.Models.ViewModels.ContractListViewModel>
@{
    ViewData["Title"] = "Quản lý hợp đồng";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h4 class="mb-0">Danh sách hợp đồng</h4>
    <a asp-action="Create" class="btn btn-primary"><i class="fas fa-file-contract me-1"></i> Tạo hợp đồng mới</a>
</div>

<div class="card border-0 shadow-sm mb-4">
    <div class="card-body">
        <form asp-action="Index" method="get" class="row g-3">
            <div class="col-md-5">
                <div class="input-group">
                    <span class="input-group-text bg-white border-end-0"><i class="fas fa-search text-muted"></i></span>
                    <input type="text" name="keyword" class="form-control border-start-0" placeholder="Tìm tên khách, số phòng, mã HĐ..." value="@ViewBag.Keyword">
                </div>
            </div>
            <div class="col-md-3">
                <select name="status" class="form-select">
                    <option value="">-- Tất cả trạng thái --</option>
                    <option value="1" selected="@(ViewBag.Status == 1)">Đang hiệu lực</option>
                    <option value="2" selected="@(ViewBag.Status == 2)">Đã kết thúc</option>
                    <option value="0" selected="@(ViewBag.Status == 0)">Đã hủy</option>
                </select>
            </div>
            <div class="col-md-4">
                <button type="submit" class="btn btn-primary px-4">Lọc</button>
                <a asp-action="Index" class="btn btn-outline-secondary px-3">Xóa bộ lọc</a>
            </div>
        </form>
    </div>
</div>

<div class="card border-0 shadow-sm">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="bg-light">
                    <tr>
                        <th class="ps-4">Mã HĐ</th>
                        <th>Khách thuê</th>
                        <th>Phòng</th>
                        <th>Thời hạn</th>
                        <th>Giá thuê</th>
                        <th>Trạng thái</th>
                        <th class="text-end pe-4">Hành động</th>
                    </tr>
                </thead>
                <tbody>
                    @if (!Model.Any())
                    {
                        <tr>
                            <td colspan="7" class="text-center py-5 text-muted">Không tìm thấy hợp đồng nào</td>
                        </tr>
                    }
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td class="ps-4 font-monospace fw-bold text-primary">@item.ContractCode</td>
                            <td>@item.TenantName</td>
                            <td>
                                <div>@item.RoomNumber</div>
                                <div class="small text-muted">@item.BuildingName</div>
                            </td>
                            <td>
                                <div class="small">Từ: @item.StartDate.ToString("dd/MM/yyyy")</div>
                                <div class="small text-danger">Đến: @item.EndDate.ToString("dd/MM/yyyy")</div>
                            </td>
                            <td class="fw-bold">@item.RentPrice.ToString("N0") ₫</td>
                            <td>
                                @if (item.Status == 1)
                                {
                                    <span class="badge bg-success">Hiệu lực</span>
                                }
                                else if (item.Status == 2)
                                {
                                    <span class="badge bg-secondary">Kết thúc</span>
                                }
                                else
                                {
                                    <span class="badge bg-danger">Hủy bỏ</span>
                                }
                            </td>
                            <td class="text-end pe-4">
                                <div class="btn-group btn-group-sm">
                                    <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-outline-info"><i class="fas fa-eye"></i></a>
                                    <a asp-action="Print" asp-route-id="@item.Id" target="_blank" class="btn btn-outline-secondary"><i class="fas fa-print"></i></a>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        @if (ViewBag.TotalPages > 1)
        {
            <div class="d-flex justify-content-center my-4 gap-2">
                @if (ViewBag.CurrentPage > 1)
                {
                    <a asp-action="Index" asp-route-page="@(ViewBag.CurrentPage - 1)" asp-route-keyword="@ViewBag.Keyword" asp-route-status="@ViewBag.Status" class="rounded-circle btn btn-primary px-3 py-2">&laquo;</a>
                }

                @{
                    int startPage = Math.Max(1, ViewBag.CurrentPage - 1);
                    int endPage = Math.Min(ViewBag.TotalPages, startPage + 2);
                    if (endPage - startPage < 2 && startPage > 1)
                    {
                        startPage = Math.Max(1, endPage - 2);
                    }
                }

                @for (int i = startPage; i <= endPage; i++)
                {
                    <a asp-action="Index" asp-route-page="@i" asp-route-keyword="@ViewBag.Keyword" asp-route-status="@ViewBag.Status" class="rounded-circle btn @(ViewBag.CurrentPage == i ? "btn-primary active" : "btn-outline-primary") px-3 py-2">@i</a>
                }

                @if (ViewBag.CurrentPage < ViewBag.TotalPages)
                {
                    <a asp-action="Index" asp-route-page="@(ViewBag.CurrentPage + 1)" asp-route-keyword="@ViewBag.Keyword" asp-route-status="@ViewBag.Status" class="rounded-circle btn btn-primary px-3 py-2">&raquo;</a>
                }
            </div>
        }
    </div>
</div>
