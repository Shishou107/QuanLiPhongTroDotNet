@model QuanLyPhongTro.Models.ViewModels.ContractCreateViewModel
@{
    ViewData["Title"] = "Thêm hợp đồng";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h4 class="mb-0">Thêm hợp đồng</h4>
    <a asp-action="Index" class="btn btn-outline-secondary">Quay lại</a>
</div>

<div class="card border-0 shadow-sm">
    <div class="card-body">
        <form asp-action="Create" method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
            <div class="row">
                <div class="col-md-6 mb-3">
                    <label asp-for="TenantId" class="form-label"></label>
                    <select asp-for="TenantId" asp-items="ViewBag.Tenants" class="form-select">
                        <option value="">Chọn khách thuê</option>
                    </select>
                    <span asp-validation-for="TenantId" class="text-danger"></span>
                </div>
                <div class="col-md-6 mb-3">
                    <label asp-for="RoomId" class="form-label"></label>
                    <select asp-for="RoomId" asp-items="ViewBag.Rooms" class="form-select">
                        <option value="">Chọn phòng trống</option>
                    </select>
                    <span asp-validation-for="RoomId" class="text-danger"></span>
                </div>
                <div class="col-md-6 mb-3">
                    <label asp-for="StartDate" class="form-label"></label>
                    <input asp-for="StartDate" class="form-control" type="date" />
                    <span asp-validation-for="StartDate" class="text-danger"></span>
                </div>
                <div class="col-md-6 mb-3">
                    <label asp-for="EndDate" class="form-label"></label>
                    <input asp-for="EndDate" class="form-control" type="date" />
                    <span asp-validation-for="EndDate" class="text-danger"></span>
                </div>
                <div class="col-md-6 mb-3">
                    <label asp-for="RentPrice" class="form-label"></label>
                    <input asp-for="RentPrice" class="form-control" type="number" min="0" step="1000" />
                    <span asp-validation-for="RentPrice" class="text-danger"></span>
                </div>
                <div class="col-md-6 mb-3">
                    <label asp-for="DepositAmount" class="form-label"></label>
                    <input asp-for="DepositAmount" class="form-control" type="number" min="0" step="1000" />
                    <span asp-validation-for="DepositAmount" class="text-danger"></span>
                </div>
                <div class="col-12 mb-3">
                    <label asp-for="Note" class="form-label"></label>
                    <textarea asp-for="Note" class="form-control" rows="3"></textarea>
                    <span asp-validation-for="Note" class="text-danger"></span>
                </div>
            </div>
            <button type="submit" class="btn btn-primary">Lưu</button>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
