@model QuanLyPhongTro.Models.ViewModels.RoomDetailViewModel
@{
    ViewData["Title"] = "Chi tiết phòng " + Model.RoomNumber;
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb mb-1">
                <li class="breadcrumb-item"><a asp-action="Index">Phòng</a></li>
                <li class="breadcrumb-item active">@Model.RoomNumber</li>
            </ol>
        </nav>
        <h4 class="mb-0">Phòng @Model.RoomNumber</h4>
    </div>
    <div class="btn-group">
        <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-outline-primary"><i class="fas fa-edit me-2"></i>Chỉnh sửa</a>
        <form asp-action="UpdateStatus" asp-route-id="@Model.Id" method="post" class="d-inline ms-2">
            @if (Model.Status == 2)
            {
                <input type="hidden" name="status" value="0" />
                <button type="submit" class="btn btn-success"><i class="fas fa-check-circle me-2"></i>Xong bảo trì</button>
            }
            else
            {
                <input type="hidden" name="status" value="2" />
                <button type="submit" class="btn btn-warning text-white"><i class="fas fa-tools me-2"></i>Đưa vào bảo trì</button>
            }
        </form>
    </div>
</div>

<div class="row">
    <div class="col-md-4">
        <div class="card shadow-sm border-0 mb-4">
            <div class="card-header bg-white py-3">
                <h6 class="mb-0 fw-bold">Thông tin phòng</h6>
            </div>
            <div class="card-body">
                <div class="text-center mb-4">
                    <div class="display-1 text-primary mb-2"><i class="fas fa-door-open"></i></div>
                    <div class="h3 fw-bold">@Model.RoomNumber</div>
                    <div>
                        @if (Model.Status == 0) { <span class="badge badge-room-empty">Trống</span> }
                        else if (Model.Status == 1) { <span class="badge badge-room-rented">Đang thuê</span> }
                        else { <span class="badge badge-room-maintenance">Bảo trì</span> }
                    </div>
                </div>
                
                <ul class="list-group list-group-flush">
                    <li class="list-group-item d-flex justify-content-between align-items-center px-0">
                        <span class="text-muted">Tòa nhà</span>
                        <span class="fw-bold text-end">@Model.BuildingName</span>
                    </li>
                    <li class="list-group-item d-flex justify-content-between align-items-center px-0">
                        <span class="text-muted">Diện tích</span>
                        <span class="fw-bold">@(Model.Area?.ToString("N1") ?? "0") m²</span>
                    </li>
                    <li class="list-group-item d-flex justify-content-between align-items-center px-0">
                        <span class="text-muted">Giá thuê cơ bản</span>
                        <span class="fw-bold text-primary">@Model.RentPrice.ToString("N0") ₫</span>
                    </li>
                </ul>
                
                @if (!string.IsNullOrEmpty(Model.Description))
                {
                    <div class="mt-3">
                        <div class="small text-muted mb-1">Mô tả:</div>
                        <p class="small mb-0">@Model.Description</p>
                    </div>
                }
            </div>
        </div>
    </div>

    <div class="col-md-8">
        @if (Model.CurrentContract != null)
        {
            <div class="card shadow-sm border-0 mb-4">
                <div class="card-header bg-white py-3 d-flex justify-content-between align-items-center">
                    <h6 class="mb-0 fw-bold">Hợp đồng hiện tại</h6>
                    <a asp-controller="Contracts" asp-action="Details" asp-route-id="@Model.CurrentContract.Id" class="btn btn-sm btn-link p-0">Chi tiết</a>
                </div>
                <div class="card-body">
                    <div class="row align-items-center">
                        <div class="col-md-6">
                            <div class="d-flex align-items-center">
                                <img src="https://ui-avatars.com/api/?name=@Model.CurrentContract.TenantName&background=0D8ABC&color=fff" class="rounded-circle me-3" width="48" height="48">
                                <div>
                                    <div class="fw-bold">@Model.CurrentContract.TenantName</div>
                                    <div class="small text-muted">Bắt đầu: @Model.CurrentContract.StartDate.ToString("dd/MM/yyyy")</div>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-6 text-md-end">
                            <div class="text-muted small">Kết thúc: @Model.CurrentContract.EndDate.ToString("dd/MM/yyyy")</div>
                            @if (Model.CurrentContract.Status == 1) { <span class="badge bg-success">Hiệu lực</span> }
                        </div>
                    </div>
                </div>
            </div>
        }
        else if (Model.Status == 0)
        {
            <div class="card shadow-sm border-0 mb-4 bg-light">
                <div class="card-body text-center py-4">
                    <p class="text-muted mb-3">Phòng này đang trống, chưa có hợp đồng thuê.</p>
                    <a asp-controller="Contracts" asp-action="Create" asp-route-roomId="@Model.Id" class="btn btn-primary px-4">Lập hợp đồng mới</a>
                </div>
            </div>
        }

        <div class="card shadow-sm border-0">
            <div class="card-header bg-white py-3">
                <h6 class="mb-0 fw-bold">Hóa đơn gần đây</h6>
            </div>
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0">
                        <thead>
                            <tr>
                                <th class="ps-4">Kỳ hạn</th>
                                <th class="text-end">Tổng tiền</th>
                                <th class="text-end">Đã trả</th>
                                <th>Trạng thái</th>
                                <th class="text-end pe-4">Hành động</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (!Model.RecentInvoices.Any())
                            {
                                <tr><td colspan="5" class="text-center py-4 text-muted">Chưa có hóa đơn nào</td></tr>
                            }
                            @foreach (var inv in Model.RecentInvoices)
                            {
                                <tr>
                                    <td class="ps-4 fw-bold">@inv.BillingMonth/@inv.BillingYear</td>
                                    <td class="text-end fw-bold text-primary">@inv.TotalAmount.ToString("N0") ₫</td>
                                    <td class="text-end text-success">@inv.PaidAmount.ToString("N0") ₫</td>
                                    <td>
                                        @if (inv.Status == 0) { <span class="badge badge-invoice-unpaid">Chưa trả</span> }
                                        else if (inv.Status == 1) { <span class="badge badge-invoice-partial">Một phần</span> }
                                        else if (inv.Status == 2) { <span class="badge badge-invoice-paid">Đã xong</span> }
                                        else { <span class="badge badge-invoice-overdue">Quá hạn</span> }
                                    </td>
                                    <td class="text-end pe-4">
                                        <a asp-controller="Invoices" asp-action="Details" asp-route-id="@inv.Id" class="btn btn-sm btn-outline-primary"><i class="fas fa-eye"></i></a>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>
