@model QuanLyPhongTro.Models.ViewModels.RoomEditViewModel
@{
    ViewData["Title"] = "Chỉnh sửa phòng";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h4 class="mb-0">Chỉnh sửa phòng</h4>
    <a asp-action="Index" class="btn btn-outline-secondary">Quay lại</a>
</div>

<div class="card border-0 shadow-sm">
    <div class="card-body">
        <form asp-action="Edit" method="post">
            <input type="hidden" asp-for="Id" />
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
            @if (Model.CurrentContract != null)
            {
                <div class="alert alert-warning">
                    Phong nay dang co hop dong hieu luc. Hay ket thuc hoac huy hop dong truoc khi chuyen phong sang Trong.
                </div>
            }
            <div class="row">
                <div class="col-md-6 mb-3">
                    <label asp-for="BuildingId" class="form-label"></label>
                    <select asp-for="BuildingId" asp-items="ViewBag.Buildings" class="form-select">
                        <option value="">Chọn tòa nhà</option>
                    </select>
                    <span asp-validation-for="BuildingId" class="text-danger"></span>
                </div>
                <div class="col-md-6 mb-3">
                    <label asp-for="RoomNumber" class="form-label"></label>
                    <input asp-for="RoomNumber" class="form-control" />
                    <span asp-validation-for="RoomNumber" class="text-danger"></span>
                </div>
                <div class="col-md-6 mb-3">
                    <label asp-for="Area" class="form-label"></label>
                    <input asp-for="Area" class="form-control" type="number" min="0" step="0.1" />
                    <span asp-validation-for="Area" class="text-danger"></span>
                </div>
                <div class="col-md-6 mb-3">
                    <label asp-for="BasePrice" class="form-label"></label>
                    <input asp-for="BasePrice" class="form-control" type="number" min="0" step="1000" />
                    <span asp-validation-for="BasePrice" class="text-danger"></span>
                </div>
                <div class="col-md-6 mb-3">
                    <label asp-for="Status" class="form-label"></label>
                    <select asp-for="Status" class="form-select">
                        @if (Model.CurrentContract == null)
                        {
                            <option value="0">Trống</option>
                        }
                        else
                        {
                            <option value="0" disabled>Trống</option>
                        }
                        <option value="1">Đang thuê</option>
                        <option value="2">Bảo trì</option>
                    </select>
                    <span asp-validation-for="Status" class="text-danger"></span>
                </div>
                <div class="col-12 mb-3">
                    <label asp-for="Description" class="form-label"></label>
                    <textarea asp-for="Description" class="form-control" rows="3"></textarea>
                    <span asp-validation-for="Description" class="text-danger"></span>
                </div>
            </div>
            <button type="submit" class="btn btn-primary">Lưu thay đổi</button>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
